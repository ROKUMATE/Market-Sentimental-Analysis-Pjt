// ─── Prisma Schema ─────────────────────────────────────────────────────────────
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ─── User ──────────────────────────────────────────────────────────────────────
model User {
  id              String            @id @default(uuid())
  email           String            @unique
  password        String
  name            String?
  isVerified      Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  preferences     UserPreference[]
  strategies      Strategy[]
  alerts          Alert[]
  userChannels    UserChannel[]
  customChannels  SocialChannel[]   @relation("CreatedByUser")
  investorProfile InvestorProfile?
  tradeOrders     TradeOrder[]
}

// ─── InvestorProfile (onboarding: risk, horizon, capital) ───────────────────
model InvestorProfile {
  id              String            @id @default(uuid())
  userId          String            @unique
  riskTolerance   Int               // 1 (conservative) to 10 (aggressive)
  horizon         InvestHorizon
  capitalAmount   Float             // in INR
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Asset ─────────────────────────────────────────────────────────────────────
model Asset {
  id              String            @id @default(uuid())
  name            String
  symbol          String            @unique
  type            AssetType
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  preferences     UserPreference[]
  posts           Post[]
}

// ─── UserPreference ────────────────────────────────────────────────────────────
model UserPreference {
  id              String            @id @default(uuid())
  userId          String
  assetId         String
  alertEnabled    Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset           Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([userId, assetId])
}

// ─── Post (ingested social post) ──────────────────────────────────────────────
model Post {
  id              String            @id @default(uuid())
  assetId         String
  source          PostSource
  externalId      String            @unique
  content         String
  author          String?
  url             String?
  postedAt        DateTime
  createdAt       DateTime          @default(now())

  asset           Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  sentiment       SentimentResult?
}

// ─── SentimentResult ───────────────────────────────────────────────────────────
model SentimentResult {
  id              String            @id @default(uuid())
  postId          String            @unique
  sentimentScore  Float             // -1 to 1
  impactScore     Float             // 0 to 100
  confidence      Float             // 0 to 1
  category        SentimentCategory
  reason          String?
  isWhaleAlert    Boolean           @default(false)
  analyzedBy      AnalysisMethod    @default(NLP)
  createdAt       DateTime          @default(now())

  post            Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
}

// ─── Strategy ──────────────────────────────────────────────────────────────────
model Strategy {
  id              String            @id @default(uuid())
  userId          String
  name            String
  description     String?
  // JSON config: { sentimentWeight, impactWeight, confidenceThreshold, etc. }
  config          Json
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Alert ─────────────────────────────────────────────────────────────────────
model Alert {
  id              String            @id @default(uuid())
  userId          String
  type            AlertType
  message         String
  metadata        Json?
  sentAt          Boolean           @default(false)
  createdAt       DateTime          @default(now())

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── SocialChannel (platform-agnostic: Twitter, Reddit, etc.) ─────────────────
model SocialChannel {
  id              String            @id @default(uuid())
  platform        SocialPlatform
  handle          String            // e.g. "CNBCTV18Live", "livemint"
  displayName     String?           // e.g. "CNBC-TV18"
  isDefault       Boolean           @default(false)
  trustScore      Float             @default(0.5)  // 0–1, higher = more trusted news source
  createdByUserId String?           // null = system default
  createdAt       DateTime          @default(now())

  createdBy       User?             @relation("CreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  followers       UserChannel[]

  @@unique([platform, handle])
}

// ─── UserChannel (join: which channels a user follows) ────────────────────────
model UserChannel {
  id              String            @id @default(uuid())
  userId          String
  channelId       String
  createdAt       DateTime          @default(now())

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel         SocialChannel     @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
}

// ─── TradeOrder — audit log of all Zerodha orders placed via the app ──────────
model TradeOrder {
  id           String    @id @default(uuid())
  userId       String
  postId       String?
  symbol       String
  exchange     String
  orderType    String
  side         String
  qty          Int
  price        Float?
  kiteOrderId  String?
  status       String    @default("PLACED")
  placedAt     DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Enums ─────────────────────────────────────────────────────────────────────
enum AssetType {
  STOCK
  CRYPTO
}

enum PostSource {
  TWITTER
  REDDIT
}

enum SocialPlatform {
  TWITTER
  REDDIT
}

enum SentimentCategory {
  SOCIAL_BUZZ
  NEWS
  RUMOR
  WHALE_ACTIVITY
}

enum AnalysisMethod {
  NLP
  LLM
}

enum AlertType {
  EMAIL
  IN_APP
}

enum InvestHorizon {
  SHORT_TERM    // < 1 week
  MEDIUM_TERM   // 1 week - 1 month
  LONG_TERM     // > 1 month
}
